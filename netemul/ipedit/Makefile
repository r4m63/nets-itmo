	@test -d $(INSTALL_ROOT)/opt/homebrew/Cellar/qt@5/5.15.18/plugins/designer || mkdir -p $(INSTALL_ROOT)/opt/homebrew/Cellar/qt@5/5.15.18/plugins/designer
	$(QINSTALL_PROGRAM) $(TARGET) $(INSTALL_ROOT)/opt/homebrew/Cellar/qt@5/5.15.18/plugins/designer/$(TARGET)
	-$(STRIP) -S -x $(INSTALL_ROOT)/opt/homebrew/Cellar/qt@5/5.15.18/plugins/designer/$(TARGET)

