####### Install

install_target: first FORCE
	@test -d $(INSTALL_ROOT)/usr/local/bin || mkdir -p $(INSTALL_ROOT)/usr/local/bin
	$(DEL_FILE) -r $(INSTALL_ROOT)/usr/local/bin/netemul.app
	
	$(QINSTALL) netemul.app $(INSTALL_ROOT)/usr/local/bin/netemul.app

uninstall_target: FORCE
	-$(DEL_FILE) -r $(INSTALL_ROOT)/usr/local/bin/netemul.app
	-$(DEL_DIR) $(INSTALL_ROOT)/usr/local/bin/ 


install_desktop: first FORCE
	@test -d $(INSTALL_ROOT)/usr/share/applications/ || mkdir -p $(INSTALL_ROOT)/usr/share/applications/
	$(QINSTALL) /Users/ramil/Downloads/netemul-1.0/netemul.desktop $(INSTALL_ROOT)/usr/share/applications/netemul.desktop

uninstall_desktop: FORCE
	-$(DEL_FILE) -r $(INSTALL_ROOT)/usr/share/applications/netemul.desktop
	-$(DEL_DIR) $(INSTALL_ROOT)/usr/share/applications/ 


install: install_target install_desktop  FORCE

uninstall: uninstall_target uninstall_desktop  FORCE

FORCE:

